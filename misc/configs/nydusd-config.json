{
  "device": {
    "backend": {
      "type": "registry",
      "config": {
        "timeout": 5,
        "connect_timeout": 5,
        "retry_limit": 2,
        "skip_verify": false,
        "ca_cert_files": ["/etc/ssl/certs/my-ca.pem"],
        "client_cert_file": "/etc/ssl/certs/client.pem",
        "client_key_file": "/etc/ssl/private/client-key.pem"
      }
    },
    "cache": {
      "type": "blobcache",
      "config": {
        "work_dir": "/var/lib/nydus/cache"
      }
    }
  },
  "mode": "direct",
  "digest_validate": false,
  "iostats_files": false,
  "enable_xattr": true,
  "fs_prefetch": {
    "enable": true,
    "threads_count": 8,
    "merging_size": 1048576,
    "prefetch_all": true
  }
}